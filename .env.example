# ─── Ollama ───────────────────────────────────────────────────────────────────
# If running Ollama on the host machine use your host's LAN IP, NOT localhost.
OLLAMA_BASE_URL=http://192.168.7.176:11434
# Optional override if generation is exposed on a different URL.
# OLLAMA_CHAT_BASE_URL=http://ai-hub.local:11434
OLLAMA_CHAT_MODEL=qwen3:1.7b

# To keep host-specific overrides from being reset during Git-based deploys,
# place only override keys in weather-llm-iac/.env.local (same KEY=VALUE format).
# deploy_nws_from_git.sh and publish_images_to_registry.sh load .env first, then
# .env.local (if present), so .env.local wins.

# ─── In-process embeddings ────────────────────────────────────────────────────
NWS_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
NWS_EMBEDDING_TIMEOUT_MS=30000
NWS_EMBEDDING_CACHE_DIR=/app/.cache/transformers

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_COLLECTION_NWS_ALERTS=nws_alerts_embeddings_v1
# Update this if your validated embedding model returns a different vector size.
QDRANT_VECTOR_SIZE=384

# ─── Host ports ───────────────────────────────────────────────────────────────
MARIADB_PORT=3307
POSTGRES_PORT=5432
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
API_PORT=3000
CLIENT_PORT=5173

# ─── Frontend ────────────────────────────────────────────────────────────────
# Browser-side API base URL. For a remote Pi deploy, set this to the Pi's
# LAN hostname or IP instead of localhost.
VITE_WEATHER_LLM_API_BASE_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Optional image-based deploys ─────────────────────────────────────────────
# Leave this false to build on the Pi. Set it to true only after publishing
# compatible images and setting the image refs below.
PREFER_PREBUILT_IMAGES=false
LOCAL_REGISTRY_HOST=192.168.6.87
LOCAL_REGISTRY_PORT=5000
# Use a unique immutable release tag instead of :latest when deploying prebuilt images.
# IMAGE_TAG=20260425-001
# WEATHER_LLM_API_IMAGE=${LOCAL_REGISTRY_HOST}:${LOCAL_REGISTRY_PORT}/weather-llm-api:${IMAGE_TAG}
# WEATHER_LLM_CLIENT_IMAGE=${LOCAL_REGISTRY_HOST}:${LOCAL_REGISTRY_PORT}/weather-llm-client:${IMAGE_TAG}
# WEATHER_LLM_NWSALERTS_IMAGE=${LOCAL_REGISTRY_HOST}:${LOCAL_REGISTRY_PORT}/weather-llm-nwsalerts:${IMAGE_TAG}

# ─── Database credentials ─────────────────────────────────────────────────────
# Use a routable IP or standard DNS name for containerized deployments.
# mDNS hosts such as *.local often do not resolve inside Docker containers.
# Change these before deploying to any shared environment.
MARIADB_ROOT_PASSWORD=emwin_root_pass
MARIADB_USER=emwin_user
MARIADB_PASSWORD=emwin_pass
MARIADB_DATABASE=emwin

POSTGRES_DB=weather_llm
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass

# ─── Ingestion location (nwsalerts service) ───────────────────────────────────
MY_LAT=36.41164391680596
MY_LON=-95.93253616680347

# ─── Email alerts (nwsalerts service) ────────────────────────────────────────
ALERT_EMAIL_USER=
ALERT_EMAIL_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ─── AQI alerts (nwsalerts / AirNow) ────────────────────────────────────────
AQI_ALERTS_ENABLED=false
AIRNOW_API_KEY=
AQI_OBSERVED_THRESHOLD=101
AQI_FORECAST_THRESHOLD=101
AIRNOW_DISTANCE_MILES=25

# ─── Manual trigger (nwsalerts internal replay endpoint) ────────────────────
# This listener stays inside the container by default. Enable it only when you
# need to replay alert processing and test it via docker exec or an ssh session.
NWS_ALERTS_MANUAL_TRIGGER_ENABLED=false
NWS_ALERTS_MANUAL_TRIGGER_HOST=127.0.0.1
NWS_ALERTS_MANUAL_TRIGGER_PORT=3011
